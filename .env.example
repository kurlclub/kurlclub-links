# SMTP settings used by /admin to email a one-time code before saving changes.
# For Gmail use port 587 with an App Password (https://myaccount.google.com/apppasswords).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="KurlClub Links <your-sender@gmail.com>"

# OTP delivery address (must match the official KurlClub mailbox).
OTP_RECIPIENT=kurlclub.official@gmail.com
